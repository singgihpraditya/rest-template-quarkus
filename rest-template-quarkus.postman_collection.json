{
  "info": {
    "_postman_id": "rest-template-quarkus-api-collection",
    "name": "REST Template Quarkus API",
    "description": "Postman Collection untuk REST Template Quarkus — Quarkus 3.8.3 + JWT\n\n**Setup:**\n1. Jalankan aplikasi dengan profile local: `mvn quarkus:dev -Dquarkus.profile=local`\n2. Import collection ini ke Postman\n3. Jalankan request **Login (Admin)** di folder Auth — token akan otomatis tersimpan ke variable `token`\n4. Semua request lain sudah dikonfigurasi menggunakan token tersebut\n\n**Default credentials:**\n- Admin: `admin / admin123`\n- User: `user / user123`\n\n**Swagger UI:** http://localhost:8080/q/swagger-ui\n**H2 Console:** http://localhost:8080/h2-console (JDBC URL: jdbc:h2:mem:logitrackdb)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL aplikasi"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token — otomatis terisi setelah request Login"
    },
    {
      "key": "category_id",
      "value": "1",
      "type": "string",
      "description": "ID kategori — ubah sesuai data yang ada"
    },
    {
      "key": "product_id",
      "value": "1",
      "type": "string",
      "description": "ID produk — ubah sesuai data yang ada"
    },
    {
      "key": "permission_id",
      "value": "",
      "type": "string",
      "description": "ID permission rule — otomatis terisi setelah request Tambah Permission"
    },
    {
      "key": "uploaded_filename",
      "value": "",
      "type": "string",
      "description": "Nama file tersimpan — otomatis terisi setelah request Upload File"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Endpoint autentikasi: login, register, dan get current user",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    const token = json.output_schema.access_token;",
                  "    pm.collectionVariables.set('token', token);",
                  "    console.log('Token tersimpan:', token.substring(0, 30) + '...');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Error code RST-000', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error_schema.error_code).to.eql('RST-000');",
                  "});",
                  "pm.test('Token ada', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.output_schema.access_token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login sebagai admin. Token JWT akan otomatis tersimpan ke variable `token`."
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.output_schema.access_token);",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login sebagai user biasa. Token JWT akan otomatis tersimpan ke variable `token`."
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Error code RST-000', () => {",
                  "    pm.expect(pm.response.json().error_schema.error_code).to.eql('RST-000');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"newpassword123\",\n  \"full_name\": \"New User\",\n  \"email\": \"newuser@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Daftarkan akun baru. Default role: ROLE_USER."
          }
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Ada username', () => {",
                  "    pm.expect(pm.response.json().output_schema.username).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Ambil data user yang sedang login berdasarkan JWT token."
          }
        },
        {
          "name": "Get Current User (dengan X-Request-Id custom)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Request-Id", "value": "my-custom-request-001", "description": "Custom requestId — akan muncul di log dan response header" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Demo pengiriman X-Request-Id custom. Nilai ini akan dikembalikan di response header X-Request-Id."
          }
        }
      ]
    },
